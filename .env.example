# FinRegQA 环境变量配置文件
# 请复制此文件为 .env 并填写实际配置

# ============================================================================
# 应用配置
# ============================================================================
DEBUG=True
APP_NAME="FinRegQA - 金融制度知识问答系统"
VERSION="1.0.0"

# ============================================================================
# MySQL数据库配置
# ============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=finregqa

# ============================================================================
# JWT配置
# ============================================================================
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24小时
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# QQ邮箱SMTP配置
# ============================================================================
# SMTP配置说明：
# 1. 登录QQ邮箱网页版
# 2. 进入 设置 -> 账户
# 3. 找到 "POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV服务"
# 4. 开启 SMTP 服务
# 5. 根据提示生成授权码（不是QQ密码）
# 6. 将授权码填入 SMTP_PASSWORD

SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_qq_email@qq.com
SMTP_PASSWORD=your_qq_authorization_code
SMTP_USE_TLS=True

# 密码重置专用密钥
PASSWORD_RESET_SECRET_KEY=password-reset-secret-key-change-in-production

# ============================================================================
# 会话管理
# ============================================================================
MAX_SESSIONS_PER_USER=3

# ============================================================================
# LLM模型配置
# ============================================================================
FINREGQA_LLM_MODEL=gpt-4o-mini
FINREGQA_LLM_BASE_URL=https://api.openai.com/v1
FINREGQA_LLM_API_KEY=your_openai_api_key
FINREGQA_LLM_TEMPERATURE=0.1